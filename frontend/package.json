{
  "name": "docsynth-frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build:operator": "vite build --mode operator",
    "build:docs": "vite build --mode docs",
    "preview": "vite preview",
    "lint": "eslint . --ext .ts,.vue",
    "format": "prettier --write \"**/*.{ts,vue,css}\"",
    "test": "vitest run",
    "e2e": "playwright test"
  },
  "dependencies": {
    "vue": "^3.5.0",
    "vue-router": "^4.4.0",
    "pinia": "^2.2.0",
    "@vueuse/core": "^11.0.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.1.0",
    "typescript": "^5.5.0",
    "vite": "^5.4.0",
    "vite-plugin-ssg": "^0.24.0",
    "vue-tsc": "^2.0.0",
    "vitest": "^2.0.0",
    "@playwright/test": "^1.47.0",
    "eslint": "^9.0.0",
    "eslint-plugin-vue": "^9.27.0",
    "prettier": "^3.3.0"
  }
}
